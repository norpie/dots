#!/bin/zsh

if (( ${+DISPLAY} )); then
    xset dpms force off
else
    export DISPLAY=:0
    xset dpms force off
    export DISPLAY=:1
    xset dpms force off
    export DISPLAY=:2
    xset dpms force off
    export DISPLAY=:3
    xset dpms force off
    export DISPLAY=:4
    xset dpms force off
    export DISPLAY=:5
    xset dpms force off
fi
