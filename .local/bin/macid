#!/bin/zsh

declare -A devices
devices=(
    ["sony"]="38:18:4C:06:79:A9"
    ["keyboard"]="E6:C9:A6:A7:E9:52"
    ["wacom"]="E0:9F:2A:1C:43:2B"
    ["beans"]="08:BF:A0:EE:20:FB"
    ["wiimote"]="00:1A:7D:DA:71:15"
    )

if [[ $# == 0 ]]; then
    for i in ${(k)devices}
    do
        echo $i
    done
    exit 1
fi

echo $devices[$1]
