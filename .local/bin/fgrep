#!/usr/bin/env bash

# Usage: fgrep <pattern> [directory]
#
# Description: greps for files matching the pattern in the specified directory (or current directory if not specified).

# Check if the pattern is provided
if [ -z "$1" ]; then
    echo "Usage: fgrep <pattern> [directory]"
    exit 1
fi

PATTERN="$1"
DIRECTORY="${2:-.}"

# Check if the specified directory exists
if [ ! -d "$DIRECTORY" ]; then
    echo "Error: Directory '$DIRECTORY' does not exist."
    exit 1
fi

# Use find to search for files and grep to filter them
find "$DIRECTORY" -type f | grep -E "$PATTERN"
