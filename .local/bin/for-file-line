#!/bin/zsh

[[ ! $# -ge 2 ]] && echo "Usage: for-file-line <file> <command>" && exit 1

command=$(echo $@ | awk '{print $2, $3, $4, $5, $6, $7}')
command=$(echo $command | awk '{$1=$1};1')


while IFS='' read -r LINE || [ -n "${LINE}" ]; do
    echo "processing command: $command ${LINE}"
    eval ${command} ${LINE}
done < $1
