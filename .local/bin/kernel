#!/bin/zsh
installed=$(pacman -Q linux | awk '{print $2}' | sed 's/.arch/-arch/g')
running=$(uname -r)

print -P "Installed: %F{green}$installed%f"

if [[ $installed == $running ]]; then
    print -P "Running: %F{green}$running%f"
    result="no"
else
    print -P "Running: %F{red}$running%f"
    result="yes"
fi
echo "Reboot for newer kernel: $result"
