#!/bin/zsh

[[ $# != 1 ]] && echo "Usage: mirror <Last part of ip>" && exit 1

# Setup adb
adb connect 192.168.0.$1:5555 &&
# Run the screen mirroring program and send it to /dev/video0
scrcpy --bit-rate=30M --max-fps=60 --lock-video-orientation --tcpip=192.168.0.$1 --v4l2-sink=/dev/video0 --no-display & 
# Wait for connection
sleep 1 && 
# Show on screen
ffplay -fs -i /dev/video0 &&
adb disconnect 192.168.0.$1
