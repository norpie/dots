# Abstraction
source ~/.config/zsh/environment.zsh || echo "error in environment"
source ~/.config/zsh/functions.zsh || echo "error in functions"
source ~/.config/zsh/binds.zsh || echo "error in binds"
source ~/.config/zsh/plugins.zsh || echo "error in plugins"
source ~/.config/zsh/settings.zsh || echo "error in settings"
source ~/.config/zsh/utils.zsh || echo "error in utils"
source ~/.config/zsh/prompt.zsh || echo "error in prompt"
